{
  "name": "omm-core",
  "version": "1.0.0",
  "description": "Ultra-lightweight 3D model engine for web — zero dependencies",
  "main": "dist/omm-core.js",
  "module": "dist/omm-core.esm.js",
  "browser": "dist/omm-core.min.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "rollup -c",
    "build:watch": "rollup -c --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": ["3d", "canvas", "webcomponent", "zero-dependencies", "omm"],
  "author": "NelikKKL",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "rollup": "^4.18.0",
    "tslib": "^2.6.3",
    "typescript": "^5.5.3"
  }
}
